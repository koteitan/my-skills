#!/usr/bin/env bash
# isbman — Isabelle build manager.
#
# Drop-in replacement for `isabelle build` that is SAFE under concurrency
# and needs NO knowledge of git / worktrees / current directory to manage
# running builds:
#
#   * Each `isbman build` prints a short "isbman-id" (an isbman-specific
#     handle — NOT a system PID and NOT Isabelle's own ID). You kill it with
#     `isbman kill <isbman-id>` from anywhere (any directory, any later shell,
#     even a build someone else started — as long as it is the same OS user).
#   * `isbman ps` lists every running build with its isbman-id, no matter
#     where it was started.
#
# How identification works: every process a build spawns (JVM, bash_process,
# the *detached* poly ML session, naproche, ...) inherits a few ISBMAN_*
# environment variables. Reaping matches the exact ISBMAN_ID via
# /proc/<pid>/environ and kills only those PIDs — never a blanket
# `pkill -f poly`. The process environment IS the registry: no state files,
# no directory dependence. (A process-group kill alone is insufficient
# because poly detaches into its own session.)
#
# How heap isolation works (an internal detail you never need to think
# about): Isabelle ignores a direct ISABELLE_HEAPS env override but honors
# USER_HOME, from which ISABELLE_HEAPS cascades. isbman points USER_HOME at a
# per-directory dir so concurrent builds in different directories never fight
# over the same <session>.db (the SQLite lock). Distribution images (HOL) are
# read from the shared system heaps; the isolated heaps are one-time seeded
# with a copy of the shared user heaps so prerequisites are not rebuilt.
#
# Subcommands:
#   isbman build [isabelle-build-args...]   # e.g. isbman build -d . -v BMS  -> prints an isbman-id
#   isbman kill <isbman-id>                 # kill that build (from anywhere)
#   isbman kill --all                       # kill every running isbman build
#   isbman kill                             # kill build(s) started from the current directory
#   isbman ps                               # list every running isbman build (isbman-id, dir, args)
#
# Env overrides:
#   ISBMAN_HOME      base dir for isolated heaps (default: ~/.cache/isbman)
#   ISBMAN_TIMEOUT   build timeout seconds       (default: 1800)
#
# Nothing project-specific is hardcoded: paths come from `isabelle getenv`,
# session names are whatever you pass to `build`.

set -u

ISBMAN_HOME="${ISBMAN_HOME:-$HOME/.cache/isbman}"
ISBMAN_TIMEOUT="${ISBMAN_TIMEOUT:-1800}"

die() { printf 'isbman: %s\n' "$*" >&2; exit 2; }

# directory used for heap isolation + as the "started-from" label. Stable
# within a git repo (any subdir maps to the repo root); else just the cwd.
build_dir() { git rev-parse --show-toplevel 2>/dev/null || pwd; }

# ---------------------------------------------------------------------------
# /proc environ helpers. Read each environ once; only same-user procs are
# readable (others are skipped), so this never touches another user's procs.
# ---------------------------------------------------------------------------
# Print "ID<TAB>DIR<TAB>ARGS<TAB>PID" for every live isbman build process.
list_procs() {
  local e env id dir args pid
  for e in /proc/[0-9]*/environ; do
    [ -r "$e" ] || continue
    env=$(tr '\0' '\n' < "$e" 2>/dev/null) || continue
    case "$env" in *ISBMAN_ID=*) ;; *) continue ;; esac
    id=$(printf '%s\n'  "$env" | sed -n 's/^ISBMAN_ID=//p'   | head -1)
    dir=$(printf '%s\n' "$env" | sed -n 's/^ISBMAN_DIR=//p'  | head -1)
    args=$(printf '%s\n' "$env" | sed -n 's/^ISBMAN_ARGS=//p' | head -1)
    pid=$(basename "$(dirname "$e")")
    printf '%s\t%s\t%s\t%s\n' "$id" "$dir" "$args" "$pid"
  done
}

reap_id() {
  local id="$1" p hit=""
  hit=$(list_procs | awk -F'\t' -v i="$id" '$1==i{print $4}')
  [ -n "$hit" ] || return 0
  for p in $hit; do kill -TERM "$p" 2>/dev/null; done
  sleep 1
  for p in $(list_procs | awk -F'\t' -v i="$id" '$1==i{print $4}'); do
    kill -KILL "$p" 2>/dev/null
  done
}

new_id() {
  # short, unique, easy to type/read
  if [ -r /dev/urandom ]; then
    od -An -N3 -tx1 /dev/urandom | tr -d ' \n'
  else
    printf '%06x' $(( (RANDOM<<8 ^ RANDOM ^ $$) & 0xffffff ))
  fi
}

# --- subcommand: build ------------------------------------------------------
cmd_build() {
  command -v isabelle >/dev/null 2>&1 || die "isabelle not on PATH"
  [ "$#" -gt 0 ] || die "usage: isbman build [isabelle-build-args...] (e.g. isbman build -d . -v BMS)"

  local dir slug isbhome orig_heaps heaps_dir id
  dir=$(build_dir)
  slug="$(basename "$dir")-$(printf '%s' "$dir" | md5sum | cut -c1-8)"
  isbhome="$ISBMAN_HOME/home/$slug"        # per-directory USER_HOME (heap isolation)

  orig_heaps=$(isabelle getenv -b ISABELLE_HEAPS 2>/dev/null)
  heaps_dir=$(USER_HOME="$isbhome" isabelle getenv -b ISABELLE_HEAPS 2>/dev/null)
  if [ -n "$heaps_dir" ] && [ ! -d "$heaps_dir" ] && [ -d "$orig_heaps" ]; then
    mkdir -p "$(dirname "$heaps_dir")"; cp -a "$orig_heaps" "$heaps_dir"
  fi

  id=$(new_id)
  echo "isbman: build started — isbman-id: $id  (in $dir)" >&2
  echo "isbman: stop it with  ->  isbman kill $id" >&2

  setsid env \
      ISBMAN_ID="$id" ISBMAN_DIR="$dir" ISBMAN_ARGS="$*" \
      USER_HOME="$isbhome" \
      timeout --kill-after=10s "$ISBMAN_TIMEOUT" \
      isabelle build "$@" &
  local launcher=$!

  trap 'echo; echo "isbman: interrupted -> killing isbman-id '"$id"'" >&2; reap_id "'"$id"'"; exit 130' INT TERM
  wait "$launcher"; local rc=$?
  trap - INT TERM
  reap_id "$id"   # sweep any escaped orphans of THIS build only

  if [ "$rc" -eq 124 ]; then
    echo "isbman: isbman-id $id TIMED OUT after ${ISBMAN_TIMEOUT}s (its processes were killed)" >&2
  fi
  return "$rc"
}

# --- subcommand: kill -------------------------------------------------------
cmd_kill() {
  local arg="${1:-}"
  case "$arg" in
    --all)
      local ids id; ids=$(list_procs | cut -f1 | sort -u)
      [ -n "$ids" ] || { echo "isbman: no builds running" >&2; return 0; }
      for id in $ids; do echo "isbman: killing isbman-id $id" >&2; reap_id "$id"; done ;;
    "")
      local dir ids id; dir=$(build_dir)
      ids=$(list_procs | awk -F'\t' -v d="$dir" '$2==d{print $1}' | sort -u)
      if [ -z "$ids" ]; then
        echo "isbman: no builds started from $dir." >&2
        echo "        Use 'isbman ps' to see all builds, then 'isbman kill <isbman-id>'." >&2
        return 0
      fi
      for id in $ids; do echo "isbman: killing isbman-id $id (started from $dir)" >&2; reap_id "$id"; done ;;
    *)
      local before; before=$(list_procs | awk -F'\t' -v i="$arg" '$1==i' | wc -l)
      if [ "$before" -eq 0 ]; then
        echo "isbman: no running build with isbman-id '$arg' (try 'isbman ps')" >&2; return 1
      fi
      reap_id "$arg"; echo "isbman: killed isbman-id $arg ($before process(es))" >&2 ;;
  esac
}

# --- subcommand: ps ---------------------------------------------------------
cmd_ps() {
  local data id n dir args pid et
  data=$(list_procs)
  if [ -z "$data" ]; then echo "(no isbman builds running)" >&2; return 0; fi
  printf '%-10s %-6s %-9s %-22s %s\n' "ISBMAN-ID" "NPROC" "ELAPSED" "DIR" "BUILD-ARGS"
  for id in $(printf '%s\n' "$data" | cut -f1 | sort -u); do
    n=$(printf '%s\n' "$data" | awk -F'\t' -v i="$id" '$1==i' | wc -l | tr -d ' ')
    dir=$(printf '%s\n' "$data" | awk -F'\t' -v i="$id" '$1==i{print $2; exit}')
    args=$(printf '%s\n' "$data" | awk -F'\t' -v i="$id" '$1==i{print $3; exit}')
    # elapsed = max etime among this build's pids (the launcher/oldest)
    et="?"
    for pid in $(printf '%s\n' "$data" | awk -F'\t' -v i="$id" '$1==i{print $4}'); do
      local e; e=$(ps -o etimes= -p "$pid" 2>/dev/null | tr -d ' ')
      [ -n "$e" ] && { [ "$et" = "?" ] && et=0; [ "$e" -gt "$et" ] && et=$e; }
    done
    [ "$et" != "?" ] && et="${et}s"
    printf '%-10s %-6s %-9s %-22s %s\n' "$id" "$n" "$et" "$(basename "$dir")" "$args"
  done
}

# --- dispatch ---------------------------------------------------------------
sub="${1:-}"; shift 2>/dev/null || true
case "$sub" in
  build) cmd_build "$@" ;;
  kill)  cmd_kill "$@" ;;
  ps)    cmd_ps "$@" ;;
  ""|-h|--help|help) sed -n '2,52p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) die "unknown subcommand '$sub' (use: build | kill | ps)" ;;
esac

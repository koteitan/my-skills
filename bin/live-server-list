#!/bin/bash
# live-server-list
# List running live-server instances: PID, URL, serving directory.

# Determine a usable IP address for building URLs.
ipaddr=$(hostname -I 2>/dev/null | awk '{print $1}')
[ -z "$ipaddr" ] && ipaddr=127.0.0.1

found=0
for pid in $(pgrep -f 'node .*live-server' 2>/dev/null); do
    cmd=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null)
    case "$cmd" in
        *live-server*) ;;
        *) continue ;;
    esac
    port=$(printf '%s\n' "$cmd" | grep -oE -- '--port=[0-9]+' | head -n1 | cut -d= -f2)
    [ -z "$port" ] && port='?'
    host=$(printf '%s\n' "$cmd" | grep -oE -- '--host=[^ ]+' | head -n1 | cut -d= -f2)
    [ -z "$host" ] && host="$ipaddr"
    url="http://$host:$port"
    dir=$(readlink -f "/proc/$pid/cwd" 2>/dev/null)
    if [ "$found" -eq 0 ]; then
        printf '%-8s %-30s %s\n' PID URL DIR
        found=1
    fi
    printf '%-8s %-30s %s\n' "$pid" "$url" "$dir"
done

[ "$found" -eq 0 ] && echo "(no live-server running)"
exit 0

#!/usr/bin/env python3
"""sessiondb - SQLite + FTS5 full-text index over Claude Code session JSONL."""
from __future__ import annotations

import argparse
import json
import os
import sqlite3
import sys
import time
from pathlib import Path
from typing import Iterator

DEFAULT_DB = Path(os.environ.get(
    "SESSIONDB_PATH",
    str(Path.home() / ".claude" / "sessiondb" / "sessions.db"),
))
PROJECTS_ROOT = Path.home() / ".claude" / "projects"
TOOL_RESULT_MAX = 64 * 1024

INGESTED_TYPES = {"user", "assistant", "system", "summary", "ai-title"}


def derive_session_id(path: Path) -> str:
    """Synthesize a collision-free session id from the JSONL path.

    Main session : projects/<proj>/<uuid>.jsonl              -> "<uuid>"
    Sub-agent    : projects/<proj>/<uuid>/subagents/<n>.jsonl-> "<uuid>/<n>"
    """
    try:
        rel = path.relative_to(PROJECTS_ROOT)
    except ValueError:
        return path.stem
    parts = rel.parts
    if len(parts) == 2:
        return parts[1].removesuffix(".jsonl")
    if len(parts) >= 4 and parts[2] == "subagents":
        return f"{parts[1]}/{parts[-1].removesuffix('.jsonl')}"
    return rel.as_posix().removesuffix(".jsonl")


def resume_id_for(session_id: str) -> str:
    """The session id you can pass to `claude --resume`."""
    return session_id.split("/", 1)[0]

SCHEMA = """
CREATE TABLE IF NOT EXISTS sessions (
  session_id  TEXT PRIMARY KEY,
  project     TEXT NOT NULL,
  cwd         TEXT,
  source_path TEXT NOT NULL UNIQUE,
  started_at  TEXT,
  ended_at    TEXT,
  msg_count   INTEGER NOT NULL DEFAULT 0,
  total_bytes INTEGER NOT NULL DEFAULT 0
);

CREATE TABLE IF NOT EXISTS messages (
  id          INTEGER PRIMARY KEY,
  session_id  TEXT NOT NULL,
  line_no     INTEGER NOT NULL,
  ts          TEXT,
  role        TEXT,
  kind        TEXT,
  tool        TEXT,
  content     TEXT NOT NULL,
  raw_len     INTEGER,
  UNIQUE (session_id, line_no)
);
CREATE INDEX IF NOT EXISTS idx_messages_session ON messages(session_id);
CREATE INDEX IF NOT EXISTS idx_messages_ts      ON messages(ts);

CREATE VIRTUAL TABLE IF NOT EXISTS messages_fts USING fts5(
  content,
  content='messages',
  content_rowid='id',
  tokenize='trigram'
);

CREATE TABLE IF NOT EXISTS files (
  source_path    TEXT PRIMARY KEY,
  size           INTEGER NOT NULL,
  mtime          REAL NOT NULL,
  indexed_lines  INTEGER NOT NULL,
  indexed_at     TEXT NOT NULL
);

CREATE TABLE IF NOT EXISTS meta (
  key   TEXT PRIMARY KEY,
  value TEXT NOT NULL
);
"""


def connect(db_path: Path) -> sqlite3.Connection:
    db_path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    conn.executescript(SCHEMA)
    conn.execute(
        "INSERT OR IGNORE INTO meta(key,value) VALUES('tokenizer','trigram')"
    )
    conn.commit()
    return conn


def flatten_tool_result(content) -> str:
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for b in content:
            if isinstance(b, dict):
                parts.append(b.get("text") or b.get("content") or "")
            else:
                parts.append(str(b))
        return "\n".join(p for p in parts if p)
    return str(content) if content is not None else ""


def flatten_line(d: dict, include_thinking: bool) -> tuple[str, str, str, str | None]:
    """Return (role, kind, content, tool_name) or ('','','',None) if skip."""
    t = d.get("type")
    if t == "summary":
        return ("", "summary", d.get("summary") or "", None)
    if t == "ai-title":
        return ("", "ai-title", d.get("title") or d.get("aiTitle") or "", None)
    if t not in ("user", "assistant", "system"):
        return ("", "", "", None)

    msg = d.get("message") or {}
    role = msg.get("role") or t
    content = msg.get("content")
    if isinstance(content, str):
        return (role, "text", content, None)
    if not isinstance(content, list):
        return (role, "text", "", None)

    text_parts: list[str] = []
    tool_name: str | None = None
    kind = "text"
    for b in content:
        if not isinstance(b, dict):
            continue
        bt = b.get("type")
        if bt == "text":
            text_parts.append(b.get("text", ""))
        elif bt == "thinking":
            if include_thinking:
                text_parts.append(b.get("thinking", ""))
        elif bt == "tool_use":
            name = b.get("name", "")
            tool_name = tool_name or name
            kind = "tool_use"
            inp = b.get("input", {})
            try:
                inp_s = json.dumps(inp, ensure_ascii=False)
            except (TypeError, ValueError):
                inp_s = str(inp)
            text_parts.append(f"[{name}] {inp_s}")
        elif bt == "tool_result":
            kind = "tool_result"
            tr = flatten_tool_result(b.get("content"))
            if len(tr.encode("utf-8")) > TOOL_RESULT_MAX:
                tr = tr.encode("utf-8")[:TOOL_RESULT_MAX].decode("utf-8", "ignore")
                tr += "\n[truncated]"
            text_parts.append(tr)
    return (role, kind, "\n".join(p for p in text_parts if p), tool_name)


def iter_jsonl(path: Path, start_line: int) -> Iterator[tuple[int, dict]]:
    with path.open("r", encoding="utf-8", errors="replace") as f:
        for i, line in enumerate(f, 1):
            if i < start_line:
                continue
            line = line.strip()
            if not line:
                continue
            try:
                yield i, json.loads(line)
            except json.JSONDecodeError:
                continue


def upsert_session(conn, session_id, project, source_path):
    conn.execute(
        """INSERT INTO sessions(session_id, project, source_path)
           VALUES(?,?,?)
           ON CONFLICT(session_id) DO UPDATE SET project=excluded.project""",
        (session_id, project, source_path),
    )


def ingest_file(conn, path: Path, start_line: int, include_thinking: bool) -> int:
    session_id = derive_session_id(path)
    try:
        project = path.relative_to(PROJECTS_ROOT).parts[0]
    except ValueError:
        project = path.parent.name
    source_path = str(path.resolve())
    upsert_session(conn, session_id, project, source_path)

    inserted = 0
    last_ts = None
    cwd = None
    last_line = start_line - 1

    for line_no, d in iter_jsonl(path, start_line):
        last_line = line_no
        role, kind, content, tool = flatten_line(d, include_thinking)
        if not kind or not content.strip():
            continue
        ts = d.get("timestamp")
        last_ts = ts or last_ts
        cwd = cwd or d.get("cwd")
        raw_len = len(json.dumps(d, ensure_ascii=False).encode("utf-8"))
        cur = conn.execute(
            """INSERT OR IGNORE INTO messages
               (session_id, line_no, ts, role, kind, tool, content, raw_len)
               VALUES (?,?,?,?,?,?,?,?)""",
            (session_id, line_no, ts, role, kind, tool, content, raw_len),
        )
        if cur.rowcount:
            inserted += 1
            conn.execute(
                "INSERT INTO messages_fts(rowid, content) VALUES (?, ?)",
                (cur.lastrowid, content),
            )

    if cwd or last_ts:
        conn.execute(
            """UPDATE sessions
               SET cwd = COALESCE(?, cwd),
                   ended_at = COALESCE(?, ended_at),
                   started_at = COALESCE(
                     (SELECT MIN(ts) FROM messages WHERE session_id=?), started_at),
                   msg_count = (SELECT COUNT(*) FROM messages WHERE session_id=?),
                   total_bytes = (SELECT COALESCE(SUM(raw_len),0) FROM messages WHERE session_id=?)
             WHERE session_id=?""",
            (cwd, last_ts, session_id, session_id, session_id, session_id),
        )
    return last_line


def purge_file(conn, source_path: str) -> None:
    session_id = derive_session_id(Path(source_path))
    rows = list(conn.execute(
        "SELECT id FROM messages WHERE session_id=?", (session_id,)
    ))
    for r in rows:
        conn.execute("INSERT INTO messages_fts(messages_fts, rowid, content) "
                     "VALUES('delete', ?, (SELECT content FROM messages WHERE id=?))",
                     (r["id"], r["id"]))
    conn.execute("DELETE FROM messages WHERE session_id=?", (session_id,))
    conn.execute("DELETE FROM sessions WHERE session_id=?", (session_id,))
    conn.execute("DELETE FROM files WHERE source_path=?", (source_path,))


def cmd_index(args) -> int:
    conn = connect(args.db)
    if args.full:
        conn.executescript(
            "DROP TABLE IF EXISTS messages_fts;"
            "DROP TABLE IF EXISTS messages;"
            "DROP TABLE IF EXISTS sessions;"
            "DROP TABLE IF EXISTS files;"
        )
        conn.commit()
        conn = connect(args.db)

    seen_paths: set[str] = set()
    t0 = time.time()
    new_files = appended = skipped = purged = 0
    new_lines = 0

    for path in sorted(PROJECTS_ROOT.rglob("*.jsonl")):
        if not path.is_file():
            continue
        sp = str(path.resolve())
        seen_paths.add(sp)
        st = path.stat()
        row = conn.execute(
            "SELECT size, indexed_lines FROM files WHERE source_path=?", (sp,)
        ).fetchone()

        if row is None:
            start = 1
            new_files += 1
        elif st.st_size == row["size"]:
            skipped += 1
            continue
        elif st.st_size > row["size"]:
            start = row["indexed_lines"] + 1
            appended += 1
        else:
            purge_file(conn, sp)
            start = 1
            purged += 1

        try:
            with conn:
                last_line = ingest_file(conn, path, start, args.include_thinking)
                added = last_line - start + 1 if last_line >= start else 0
                new_lines += max(0, added)
                conn.execute(
                    """INSERT INTO files(source_path,size,mtime,indexed_lines,indexed_at)
                       VALUES(?,?,?,?,?)
                       ON CONFLICT(source_path) DO UPDATE SET
                         size=excluded.size, mtime=excluded.mtime,
                         indexed_lines=excluded.indexed_lines,
                         indexed_at=excluded.indexed_at""",
                    (sp, st.st_size, st.st_mtime,
                     max(last_line, row["indexed_lines"] if row else 0),
                     time.strftime("%Y-%m-%dT%H:%M:%S")),
                )
        except Exception as e:
            print(f"  ! 取り込み失敗 {path}: {e}", file=sys.stderr)

    deleted = 0
    for r in conn.execute("SELECT source_path FROM files"):
        if r["source_path"] not in seen_paths:
            purge_file(conn, r["source_path"])
            deleted += 1
    conn.commit()

    dt = time.time() - t0
    print(
        f"完了 ({dt:.1f}s): 新規 {new_files} / 追記 {appended} / "
        f"スキップ {skipped} / 再構築 {purged} / 削除 {deleted} / "
        f"追加メッセージ {new_lines}"
    )
    return 0


def cmd_list_sessions(conn, args) -> int:
    ignored = []
    if args.role:
        ignored.append("--role")
    if args.context != 5:
        ignored.append("--context")
    if args.highlight:
        ignored.append("--highlight")
    if args.snippet != 96:
        ignored.append("--snippet")
    if args.sort == "score":
        pass
    if ignored:
        print(f"# 警告: query 省略時 (セッション一覧モード) では {', '.join(ignored)} "
              "は無視されます", file=sys.stderr)

    sql = ("SELECT session_id, project, source_path, "
           "COALESCE(ended_at, started_at) AS ts, "
           "msg_count, total_bytes "
           "FROM sessions WHERE 1=1 ")
    params: list = []
    if args.project:
        sql += "AND project LIKE ? "
        params.append(f"%{args.project}%")
    sort = "ASC" if args.sort == "date-asc" else "DESC"
    sql += f"ORDER BY COALESCE(ended_at, started_at) {sort} LIMIT ?"
    params.append(args.limit)

    t0 = time.time()
    rows = list(conn.execute(sql, params))
    dt_ms = int((time.time() - t0) * 1000)

    if not rows:
        print("（該当セッションなし）")
        return 0

    if args.interactive or args.format == "table":
        idx_width = len(str(len(rows)))
        for i, r in enumerate(rows, 1):
            ts = (r["ts"] or "")[:19].replace("T", " ")
            size_mb = (r["total_bytes"] or 0) / 1024 / 1024
            prefix = f"{i:>{idx_width}}: " if args.interactive else ""
            print(f"{prefix}{ts}\t{r['session_id']}\t"
                  f"msgs:{r['msg_count']}\t{size_mb:6.1f}MB\t{r['project']}")
        print(f"# {len(rows)} sessions / {dt_ms} ms", file=sys.stderr)

        if not args.interactive:
            print("# セッションを開く: sessiondb show <session_id>", file=sys.stderr)
            return 0

        while True:
            try:
                s = input("\n> ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                return 0
            if s == "" or s in ("q", "quit", "exit"):
                return 0
            if s in ("a", "all", "*"):
                indices = list(range(1, len(rows) + 1))
            else:
                indices = parse_indices(s, len(rows))
            if indices is None:
                print(f"入力エラー。例: 2 / 1,3,5 / 1-8 / all  "
                      f"(範囲 1-{len(rows)})", file=sys.stderr)
                continue
            for n, k in enumerate(indices):
                r = rows[k - 1]
                if n == 0:
                    print()
                else:
                    print("\n" + "─" * 70)
                print(f"### Session {k}: {r['session_id']} "
                      f"({r['msg_count']} msgs)\n")
                render_messages(conn, r["session_id"],
                                line=None, context=0, full=False)
        return 0

    for r in rows:
        print(json.dumps({
            "session_id": r["session_id"],
            "project": r["project"],
            "ts": r["ts"],
            "msg_count": r["msg_count"],
            "total_bytes": r["total_bytes"],
            "source_path": r["source_path"],
            "resume": f"claude --resume {resume_id_for(r['session_id'])}",
        }, ensure_ascii=False))
    print(json.dumps({"_summary": {
        "sessions": len(rows), "ms": dt_ms,
    }}, ensure_ascii=False))
    return 0


def cmd_search(args) -> int:
    conn = connect(args.db)
    if args.query is None or args.query.strip() == "":
        return cmd_list_sessions(conn, args)
    sql = (
        "SELECT m.session_id, m.line_no, m.ts, m.role, s.source_path, s.project, "
        f"snippet(messages_fts, 0, '<b>', '</b>', '…', {int(args.snippet)}) AS snippet, "
        "bm25(messages_fts) AS score "
        "FROM messages_fts "
        "JOIN messages m ON m.id = messages_fts.rowid "
        "JOIN sessions s ON s.session_id = m.session_id "
        "WHERE messages_fts MATCH ? "
    )
    params: list = [args.query]
    if args.project:
        sql += "AND s.project LIKE ? "
        params.append(f"%{args.project}%")
    if args.role:
        sql += "AND m.role = ? "
        params.append(args.role)
    if args.sort == "date":
        sql += "ORDER BY m.ts DESC, score "
    elif args.sort == "date-asc":
        sql += "ORDER BY m.ts ASC, score "
    else:
        sql += "ORDER BY score "
    sql += "LIMIT ?"
    params.append(args.limit)

    t0 = time.time()
    rows = list(conn.execute(sql, params))
    dt_ms = int((time.time() - t0) * 1000)

    def clean(s: str | None) -> str:
        if not s:
            return ""
        s = s.replace("\n", " ").replace("\r", " ").replace("\t", " ")
        if not args.highlight:
            s = s.replace("<b>", "").replace("</b>", "")
        return s

    if args.interactive or args.format == "table":
        if not rows:
            print("（該当なし）")
            return 0
        idx_width = len(str(len(rows)))
        for i, r in enumerate(rows, 1):
            ts = (r["ts"] or "")[:19].replace("T", " ")
            prefix = f"{i:>{idx_width}}: " if args.interactive else ""
            print(f"{prefix}{ts}\t{r['session_id']}\tL{r['line_no']}\t"
                  f"{r['project']}\t{clean(r['snippet'])}")
        print(f"# {len(rows)} 件 / {dt_ms} ms", file=sys.stderr)
        if not args.interactive:
            print("# 続きを見る: sessiondb show <session_id> --line <L> --context 5",
                  file=sys.stderr)
            return 0

        # 対話ループ
        while True:
            try:
                s = input("\n> ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                return 0
            if s == "" or s in ("q", "quit", "exit"):
                return 0
            if s in ("a", "all", "*"):
                indices = list(range(1, len(rows) + 1))
            else:
                indices = parse_indices(s, len(rows))
            if indices is None:
                print(f"入力エラー。例: 2 / 1,3,5 / 1-8 / 1,3-5,7 / all  "
                      f"(範囲 1-{len(rows)})", file=sys.stderr)
                continue
            for n, k in enumerate(indices):
                r = rows[k - 1]
                if n == 0:
                    print()
                else:
                    print("\n" + "─" * 70)
                print(f"### Hit {k}: {r['session_id']} L{r['line_no']}\n")
                render_messages(conn, r["session_id"], r["line_no"],
                                args.context, full=False)

    for r in rows:
        print(json.dumps({
            "session_id": r["session_id"],
            "project": r["project"],
            "ts": r["ts"],
            "role": r["role"],
            "snippet": clean(r["snippet"]),
            "score": r["score"],
            "source_path": r["source_path"],
            "line_no": r["line_no"],
            "resume": f"claude --resume {resume_id_for(r['session_id'])}",
        }, ensure_ascii=False))
    print(json.dumps({"_summary": {
        "hits": len(rows), "shown": len(rows),
        "query": args.query, "ms": dt_ms,
    }}, ensure_ascii=False))
    return 0


def cmd_stats(args) -> int:
    conn = connect(args.db)
    total_sessions = conn.execute("SELECT COUNT(*) FROM sessions").fetchone()[0]
    total_messages = conn.execute("SELECT COUNT(*) FROM messages").fetchone()[0]
    total_bytes = conn.execute(
        "SELECT COALESCE(SUM(total_bytes),0) FROM sessions"
    ).fetchone()[0]
    print(f"セッション数: {total_sessions}")
    print(f"メッセージ数: {total_messages}")
    print(f"総バイト数:   {total_bytes/1024/1024:.1f} MB")
    print("\nプロジェクト別 (上位 10):")
    for r in conn.execute(
        "SELECT project, COUNT(*) AS n, SUM(total_bytes) AS b "
        "FROM sessions GROUP BY project ORDER BY n DESC LIMIT 10"
    ):
        print(f"  {r['n']:5d}  {(r['b'] or 0)/1024/1024:7.1f} MB  {r['project']}")
    print("\n最大セッション (上位 5):")
    for r in conn.execute(
        "SELECT session_id, project, total_bytes "
        "FROM sessions ORDER BY total_bytes DESC LIMIT 5"
    ):
        print(f"  {r['total_bytes']/1024/1024:7.1f} MB  {r['session_id'][:8]}  {r['project']}")
    return 0


def cmd_size(args) -> int:
    db = Path(args.db)
    if not db.exists():
        print(f"（DB が存在しません: {db}）", file=sys.stderr)
        return 1

    def human(n: int) -> str:
        f = float(n)
        for unit in ("B", "KB", "MB", "GB", "TB"):
            if f < 1024 or unit == "TB":
                return f"{f:.1f} {unit}" if unit != "B" else f"{int(f)} B"
            f /= 1024
        return f"{f:.1f} TB"

    # 本体 + WAL/SHM サイドカーのディスク使用量
    main = db.stat().st_size
    wal = (db.parent / (db.name + "-wal"))
    shm = (db.parent / (db.name + "-shm"))
    wal_sz = wal.stat().st_size if wal.exists() else 0
    shm_sz = shm.stat().st_size if shm.exists() else 0
    total = main + wal_sz + shm_sz

    conn = connect(args.db)
    page_size = conn.execute("PRAGMA page_size").fetchone()[0]
    page_count = conn.execute("PRAGMA page_count").fetchone()[0]
    freelist = conn.execute("PRAGMA freelist_count").fetchone()[0]
    free_bytes = freelist * page_size

    if args.format == "json":
        print(json.dumps({
            "db_path": str(db),
            "file_bytes": main,
            "wal_bytes": wal_sz,
            "shm_bytes": shm_sz,
            "total_bytes": total,
            "page_size": page_size,
            "page_count": page_count,
            "freelist_count": freelist,
            "free_bytes": free_bytes,
        }, ensure_ascii=False))
        return 0

    print(f"DB:           {db}")
    print(f"本体:         {human(main)}")
    if wal_sz:
        print(f"WAL:          {human(wal_sz)}")
    if shm_sz:
        print(f"SHM:          {human(shm_sz)}")
    print(f"ディスク合計: {human(total)}")
    print(f"ページ:       {page_count} pages × {page_size} B "
          f"(空き {freelist} pages = {human(free_bytes)})")
    return 0


def resolve_session_id(conn, given: str) -> str | None:
    """Accept either a full session_id or a unique prefix (>= 4 chars).

    When the prefix matches both a main session and its sub-agents, the main
    session (no slash) wins.
    """
    row = conn.execute(
        "SELECT session_id FROM sessions WHERE session_id=?", (given,)
    ).fetchone()
    if row:
        return row["session_id"]
    if len(given) < 4:
        return None
    matches = [r["session_id"] for r in conn.execute(
        "SELECT session_id FROM sessions WHERE session_id LIKE ? LIMIT 20",
        (given + "%",),
    )]
    if not matches:
        return None
    if len(matches) == 1:
        return matches[0]
    main_only = [m for m in matches if "/" not in m]
    if len(main_only) == 1:
        return main_only[0]
    print("曖昧なプレフィックス。候補:", file=sys.stderr)
    for m in matches[:10]:
        print(f"  {m}", file=sys.stderr)
    return None


def parse_indices(s: str, max_idx: int) -> list[int] | None:
    """Parse selection like '1', '1,3,5', '1-8', '1,3-5,7'.
    Returns None on any malformed token or out-of-range value.
    """
    out: list[int] = []
    for part in s.replace(" ", "").split(","):
        if not part:
            continue
        if "-" in part:
            a, _, b = part.partition("-")
            try:
                lo, hi = int(a), int(b)
            except ValueError:
                return None
            if lo > hi:
                lo, hi = hi, lo
            for k in range(lo, hi + 1):
                if not 1 <= k <= max_idx:
                    return None
                out.append(k)
        else:
            try:
                k = int(part)
            except ValueError:
                return None
            if not 1 <= k <= max_idx:
                return None
            out.append(k)
    return out or None


def render_messages(conn, session_id: str, line: int | None,
                    context: int, full: bool) -> int:
    """Print messages for a session, optionally a window around `line`."""
    sql = ("SELECT line_no, ts, role, kind, tool, content "
           "FROM messages WHERE session_id=?")
    params: list = [session_id]
    if line is not None:
        lo = max(1, line - context)
        hi = line + context
        sql += " AND line_no BETWEEN ? AND ?"
        params += [lo, hi]
    sql += " ORDER BY line_no"
    rows = list(conn.execute(sql, params))
    if not rows:
        print("（該当なし: line_no を確認）", file=sys.stderr)
        return 1
    for r in rows:
        ts = (r["ts"] or "")[:19].replace("T", " ")
        marker = " <==" if line == r["line_no"] else ""
        head = f"[{r['line_no']:4d}] {ts} {r['role'] or '-'}/{r['kind']}{marker}"
        if r["tool"]:
            head += f" {r['tool']}"
        print(head)
        body = r["content"]
        if len(body) > 1000 and not full:
            body = body[:1000] + f"\n  … ({len(body)} chars total; --full で全表示)"
        for ln in body.splitlines():
            print(f"    {ln}")
    return 0


def cmd_show(args) -> int:
    conn = connect(args.db)
    resolved = resolve_session_id(conn, args.session_id)
    if resolved is None:
        print(f"（session_id が見つかりません: {args.session_id}）", file=sys.stderr)
        return 1
    if resolved != args.session_id:
        print(f"# {args.session_id} → {resolved}", file=sys.stderr)
    return render_messages(conn, resolved, args.line, args.context, args.full)


def build_parser() -> tuple[argparse.ArgumentParser, argparse._SubParsersAction]:
    p = argparse.ArgumentParser(
        prog="sessiondb",
        description="Claude Code のセッション JSONL を SQLite + FTS5 で全文検索",
        epilog="サブコマンドの詳細は `sessiondb help <subcommand>`",
    )
    p.add_argument("--db", type=Path, default=DEFAULT_DB,
                   help=f"SQLite ファイルのパス (default: {DEFAULT_DB}; "
                        "環境変数 SESSIONDB_PATH でも指定可)")
    sub = p.add_subparsers(dest="cmd", required=True,
                           metavar="{index,search,stats,size,show,help}")

    p_index = sub.add_parser(
        "index", help="増分または全インデックス",
        description="~/.claude/projects/ 配下の JSONL を走査してインデックス更新",
    )
    p_index.add_argument("--full", action="store_true",
                         help="既存テーブルを drop してゼロから再構築")
    p_index.add_argument("--include-thinking", action="store_true",
                         help="thinking ブロックも索引に含める (既定: 含めない)")
    p_index.set_defaults(func=cmd_index)

    p_search = sub.add_parser(
        "search", help="全文検索",
        description="FTS5 trigram で全文検索。query は 3 文字以上推奨",
    )
    p_search.add_argument("query", nargs="?", default=None,
                          help="検索クエリ (FTS5 MATCH 構文)。"
                               "省略時はセッション一覧モード (新しい順)")
    p_search.add_argument("--project",
                          help="プロジェクト名で絞り込み (部分一致 LIKE)")
    p_search.add_argument("--role", choices=["user", "assistant", "system"],
                          help="メッセージ role で絞り込み")
    p_search.add_argument("--limit", type=int, default=20,
                          help="返す件数 (default: 20)")
    p_search.add_argument("--snippet", type=int, default=96,
                          help="snippet のトークン幅 (default: 96, "
                               "trigram では概ね同数の文字数になる)")
    p_search.add_argument("--sort", choices=["score", "date", "date-asc"],
                          default="score",
                          help="並び順: score=関連度(既定) / date=新しい順 / "
                               "date-asc=古い順")
    p_search.add_argument("--highlight", action="store_true",
                          help="ヒット箇所を <b>...</b> で囲んで表示 "
                               "(既定: タグ無し)")
    p_search.add_argument("--format", choices=["jsonl", "table"], default="table",
                          help="出力形式 (default: table, 人間向け; "
                               "jsonl はエージェント向け)")
    p_search.add_argument("-i", "--interactive", action="store_true",
                          help="番号付きで一覧表示し、番号入力で show を呼ぶ "
                               "(--format は無視して table 風)")
    p_search.add_argument("--context", type=int, default=5,
                          help="--interactive 時、選択ヒットの前後何メッセージを "
                               "表示するか (default: 5)")
    p_search.set_defaults(func=cmd_search)

    p_stats = sub.add_parser(
        "stats", help="統計表示",
        description="総セッション数・プロジェクト別件数・最大セッションを表示",
    )
    p_stats.set_defaults(func=cmd_stats)

    p_size = sub.add_parser(
        "size", help="DB のディスク使用量を表示",
        description="SQLite DB 本体 + WAL/SHM のディスク使用量とページ統計を表示 "
                    "(stats の総バイト数=元 JSONL 合計とは別物)",
    )
    p_size.add_argument("--format", choices=["text", "json"], default="text",
                        help="出力形式 (default: text; json はエージェント向け)")
    p_size.set_defaults(func=cmd_size)

    p_show = sub.add_parser(
        "show", help="セッションを時系列で出力",
        description="指定セッションの全メッセージを line_no 順に表示",
    )
    p_show.add_argument("session_id",
                        help="UUID または曖昧でないプレフィックス (4文字以上)。"
                             "サブエージェントは <parent_uuid>/agent-XXX")
    p_show.add_argument("--line", type=int,
                        help="特定の line_no を中心に表示 (search の L 列の数値)")
    p_show.add_argument("--context", type=int, default=5,
                        help="--line 指定時、前後 N メッセージを表示 (default: 5)")
    p_show.add_argument("--full", action="store_true",
                        help="長いメッセージも切り詰めずに表示")
    p_show.set_defaults(func=cmd_show)

    p_help = sub.add_parser(
        "help", help="全コマンドの詳細ヘルプを表示",
        description="`sessiondb help` で全体、`sessiondb help <cmd>` で個別",
    )
    p_help.add_argument("topic", nargs="?",
                        help="ヘルプを表示するサブコマンド名 (省略時は全表示)")
    p_help.set_defaults(func=None)
    return p, sub


def main() -> int:
    argv = list(sys.argv[1:])
    # `help` を `--help` の別名として任意位置で受け付ける
    if argv:
        if argv[0] == "help":
            argv = [argv[1], "--help"] + argv[2:] if len(argv) > 1 else []
        elif len(argv) >= 2 and argv[1] == "help":
            argv = [argv[0], "--help"]

    p, _sub = build_parser()
    # 引数ゼロ / `help` / `--help` 単独ではトップレベルだけを出す
    if not argv or argv == ["--help"] or argv == ["-h"]:
        p.print_help()
        return 0

    args = p.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())

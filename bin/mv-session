#!/bin/bash
set -euo pipefail

if [ "$#" -ne 2 ]; then
    echo "Usage: $(basename "$0") <src> <dst>" >&2
    echo "  Moves a directory and its corresponding ~/.claude/projects/ session directory." >&2
    exit 1
fi

src_abs=$(realpath -m "$1")
dst_abs=$(realpath -m "$2")

path_to_session() {
    echo "$1" | sed -e 's|/|-|g' -e 's|\.|-|g'
}

src_session="$HOME/.claude/projects/$(path_to_session "$src_abs")"
dst_session="$HOME/.claude/projects/$(path_to_session "$dst_abs")"

if [ ! -e "$src_abs" ]; then
    echo "Error: source directory does not exist: $src_abs" >&2
    exit 1
fi

if [ -e "$dst_abs" ]; then
    echo "Error: destination already exists: $dst_abs" >&2
    exit 1
fi

if [ -e "$dst_session" ]; then
    echo "Error: destination session already exists: $dst_session" >&2
    exit 1
fi

echo "Moving directory:"
echo "  $src_abs"
echo "  -> $dst_abs"
mv "$src_abs" "$dst_abs"

if [ -e "$src_session" ]; then
    echo "Moving session:"
    echo "  $src_session"
    echo "  -> $dst_session"
    mv "$src_session" "$dst_session"
else
    echo "Note: no session directory found at $src_session (skipped)"
fi

echo "Done."
